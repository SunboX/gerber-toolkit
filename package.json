{
    "name": "gerber-toolkit",
    "version": "0.4.1",
    "description": "Gerber and Excellon fabrication parsing and deterministic SVG rendering utilities",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SunboX/gerber-toolkit.git"
    },
    "keywords": [
        "gerber",
        "excellon",
        "pcb",
        "eda",
        "ecad",
        "fabrication",
        "parser",
        "renderer",
        "svg",
        "javascript",
        "esm"
    ],
    "license": "GPL-3.0-or-later",
    "type": "module",
    "main": "./src/index.mjs",
    "exports": {
        ".": "./src/index.mjs",
        "./parser": "./src/parser.mjs",
        "./project": "./src/project.mjs",
        "./renderers": "./src/renderers.mjs",
        "./interaction": "./src/interaction.mjs",
        "./query": "./src/query.mjs",
        "./manufacturing": "./src/manufacturing.mjs",
        "./simulation": "./src/simulation.mjs",
        "./scene3d": "./src/scene3d.mjs",
        "./capabilities": "./src/capabilities.mjs",
        "./extensions": "./src/extensions.mjs",
        "./testing": "./src/testing.mjs",
        "./workers/parser.worker.mjs": "./src/workers/parser.worker.mjs",
        "./styles/renderers.css": "./src/styles/renderers.css"
    },
    "files": [
        "src",
        "docs",
        "spec/*.md",
        "LICENSE",
        "LICENSES",
        "COMMERCIAL-LICENSE.md",
        "CONTRIBUTING.md",
        "NOTICE.md",
        "README.md",
        "AGENTS.md",
        "REUSE.toml"
    ],
    "scripts": {
        "test": "node --test",
        "format": "prettier --write .",
        "check:format": "prettier --check .",
        "capture:api": "node scripts/capture-api-baseline.mjs",
        "check:features": "node scripts/check-feature-preservation.mjs",
        "benchmark": "node --expose-gc scripts/run-benchmarks.mjs --compare benchmarks/baseline-v0.1.21.json"
    },
    "dependencies": {
        "circuitjson-toolkit": "^1.4.0",
        "fflate": "^0.8.2",
        "polygon-clipping": "^0.15.7"
    },
    "devDependencies": {
        "prettier": "^3.4.2"
    },
    "engines": {
        "node": ">=20"
    }
}
